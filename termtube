#!/usr/bin/env bash
# TermTube entry point — resolves the .venv created by setup.sh and runs main.py.

set -euo pipefail

# Resolve symlinks to find the true script directory
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# ── Handle Uninstall ───────────────────────────────────────────────────────
if [[ "${1:-}" == "--uninstall" ]]; then
    UNINSTALLER="$SCRIPT_DIR/uninstall.sh"
    if [[ -f "$UNINSTALLER" ]]; then
        exec "$UNINSTALLER"
    else
        echo "Error: Uninstaller script not found at $UNINSTALLER"
        exit 1
    fi
fi

# ── Find Python ────────────────────────────────────────────────────────────

find_python() {
    local venv_py="$SCRIPT_DIR/.venv/bin/python3"
    if [[ -f "$venv_py" ]]; then
        echo "$venv_py"
        return 0
    fi
    return 1
}

# ── Main ───────────────────────────────────────────────────────────────────

if ! PYTHON=$(find_python 2>/dev/null); then
    echo ""
    echo -e "  \033[1;31m✗ No TermTube Python environment found.\033[0m"
    echo ""
    echo "  Run the one-time setup script first:"
    echo -e "    \033[1;32mbash setup.sh\033[0m"
    echo ""
    exit 1
fi

exec "$PYTHON" "$SCRIPT_DIR/src/main.py" "$@"
